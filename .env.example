# ===================================================================
# AI 3D Modeling System - Environment Template
# Copy this file to `.env` and fill in the values you need.
# ===================================================================

# ==============================
# Docker Images & Compose
# ==============================
# Private registry host:port used for push and pull.
DOCKER_REGISTRY=registry.katrina.kim:10443

# Repository namespace used under the registry.
DOCKERHUB_NAMESPACE=luanpao779588955

# Image tag used for server / web / full images.
IMAGE_TAG=latest

# Host port exposed by the web container.
WEB_PORT=4173

# ==============================
# Server Runtime
# ==============================
# API listen port for the Fastify backend.
PORT=3000

# Listen host. Use `0.0.0.0` for Docker / LAN access.
HOST=0.0.0.0

# ==============================
# Database
# ==============================
# PostgreSQL connection string used by the backend.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_3d_modeling

# Connection string used by containers to reach the bundled PostgreSQL service.
DATABASE_URL_DOCKER=postgresql://postgres:postgres@db:5432/ai_3d_modeling

# Host port published by the local PostgreSQL container.
DATABASE_PORT=5432

# Set to true/require when the PostgreSQL endpoint needs SSL.
DATABASE_SSL=false

# ==============================
# Asset Registry
# ==============================

# JSON registry file for reusable normalized assets.
ASSET_REGISTRY_PATH=./apps/server/data/asset-registry.json

# ==============================
# AI Provider Settings
# ==============================
# Supported: `mock`, `openai`
AI_PROVIDER=mock

# Model name for the selected provider.
# Examples:
#   gpt-4o-mini
#   gpt-4.1-mini
AI_MODEL=

# OpenAI-compatible API key.
OPENAI_API_KEY=

# OpenAI-compatible base URL.
# Default OpenAI: https://api.openai.com/v1
# OpenRouter example: https://openrouter.ai/api/v1
# Azure/OpenAI proxy: set your compatible endpoint here
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# Web App
# ==============================
# Browser frontend API endpoint.
VITE_API_URL=http://localhost:3000

# ==============================
# Electron Desktop
# ==============================
# Backend endpoint used by the Electron preload bridge.
ELECTRON_API_URL=http://127.0.0.1:3000

# Renderer URL used by Electron during local development.
ELECTRON_RENDERER_URL=http://127.0.0.1:5173
